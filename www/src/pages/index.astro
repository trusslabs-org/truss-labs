---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Truss Labs">
	<main class="pb-20 text-text leading-relaxed antialiased selection:bg-accent selection:text-black">
		<div class="mb-16 text-sm">
			<p class="mb-4 text-dim">
				Truss is an open-source audit proxy that lets enterprises safely use any AI model by sanitizing prompts at the browser edge and logging verified transaction receipts inside their own secure hardware enclaves.
			</p>
			<p class="text-dim">
				We help you bypass expensive, cloud-locked AI security suites. By intercepting data at the browser DOM or API gateway, Truss ensures sensitive data is redacted locally before it ever reaches public model providers. No SaaS middlemen; complete cryptographic sovereignty.
			</p>
		</div>

		<!-- Interactive Browser & Ledger Simulator (Path B) -->
		<div class="mb-16">
			<div class="grid grid-cols-1 md:grid-cols-12 gap-6 mb-6">
				<!-- Column 1: Simulated Browser Window (7 cols) -->
				<div class="md:col-span-7 relative rounded border border-border-dim bg-black/40 overflow-hidden shadow-2xl flex flex-col h-[340px]">
					<!-- Browser Header Bar -->
					<div class="flex items-center justify-between gap-2 px-4 py-3 border-b border-border-dim bg-surface select-none">
						<div class="flex gap-1.5 shrink-0">
							<span class="w-3 h-3 rounded-full bg-border-dim"></span>
							<span class="w-3 h-3 rounded-full bg-border-dim"></span>
							<span class="w-3 h-3 rounded-full bg-border-dim"></span>
						</div>
						<!-- Address bar mock -->
						<div class="flex items-center gap-1.5 px-3 py-1 bg-black/30 rounded border border-border-dim text-[11px] text-dim font-mono flex-1 max-w-[180px] justify-center">
							<span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
							<span>chatgpt.com</span>
						</div>
						<!-- Extension Shield Indicator - Fixed horiz padding & shrink behavior -->
						<div class="flex items-center gap-1.5 px-3 py-1 rounded border border-accent/20 bg-accent/5 shrink-0" id="extension-status">
							<span class="w-1.5 h-1.5 rounded-full bg-accent transition-colors duration-300 shrink-0" id="extension-indicator"></span>
							<span class="text-[9px] text-accent font-mono uppercase font-bold tracking-wider whitespace-nowrap" id="extension-text">truss active</span>
						</div>
					</div>
					
					<!-- Simulated Webpage viewport -->
					<div class="p-4 flex-1 flex flex-col justify-between bg-surface font-mono relative overflow-hidden">
						<!-- Chat thread message log -->
						<div class="flex-1 flex flex-col gap-3 justify-end pb-4 text-xs">
							<!-- User message block -->
							<div class="flex flex-col gap-1 max-w-[85%] self-end items-end opacity-0 transition-opacity duration-300" id="msg-user">
								<span class="text-[10px] text-dim select-none uppercase tracking-wider">User</span>
								<div class="bg-surface-variant border border-border-dim p-2.5 rounded text-dim" id="msg-user-text">
								</div>
							</div>
							
							<!-- Truss security alert banner -->
							<div class="flex flex-col gap-1 max-w-[95%] self-start opacity-0 transform translate-y-2 transition-all duration-300" id="msg-alert">
								<span class="text-[10px] text-dim select-none uppercase tracking-wider">Truss Edge Interceptor</span>
								<div class="bg-red-500/5 border border-red-500/20 text-red-400 p-2.5 rounded text-xs leading-relaxed">
									<div class="flex items-center gap-1.5 font-bold mb-1">
										<span class="text-sm">🛡️</span>
										<span>Truss Security Block</span>
									</div>
									<p class="text-[11px] text-red-300/80">
										PHI patient address detected in outbound fetch request. Outbound request aborted locally. No data sent to OpenAI.
									</p>
								</div>
							</div>
						</div>

						<!-- Input Box bottom container - Adjusted heights, margins, and alignments to prevent character clipping -->
						<div class="pt-3 border-t border-border-dim flex items-start justify-between gap-3 bg-surface">
							<div class="text-[11px] leading-relaxed text-dim flex-1 min-h-[38px] overflow-hidden flex items-start relative py-0.5" id="prompt-input-container">
								<span id="prompt-input" class="text-dim break-words w-full"></span>
								<span id="cursor" class="w-1.5 h-3.5 bg-accent ml-0.5 animate-pulse shrink-0 mt-0.5"></span>
							</div>
							<button class="px-3 py-1 rounded bg-surface-variant border border-border-dim text-[11px] text-dim hover:text-text transition-colors select-none shrink-0" id="btn-send">
								Send
							</button>
						</div>
					</div>
				</div>

				<!-- Column 2: Simulated Local Terminal (5 cols) -->
				<div class="md:col-span-5 relative rounded border border-border-dim bg-black/40 overflow-hidden shadow-2xl flex flex-col h-[340px]">
					<div class="flex items-center gap-2 px-4 py-3 border-b border-border-dim bg-surface select-none">
						<span class="text-xs text-dim font-mono">Local Compliance Ledger (~/.truss/ledger)</span>
					</div>
					<div class="p-4 flex-1 bg-surface font-mono overflow-y-auto flex flex-col gap-3 text-[11px]">
						<!-- Logger stream event -->
						<div class="text-dim leading-relaxed opacity-0 transition-opacity duration-300" id="log-event">
							<span class="text-accent font-bold">[SUCCESS]</span> Written transaction receipt:
						</div>
						
						<!-- JSON Block mock with Astro string literal escaping -->
						<pre class="bg-black/20 border border-border-dim rounded p-3 text-[10px] leading-relaxed text-dim opacity-0 transform translate-y-1 transition-all duration-300 flex-1 overflow-x-auto" id="log-receipt"><code>{`{
  "verdict": "blocked",
  "matched_rules": [
    "phi_block_address"
  ],
  "evidence": {
    "receipt_hash": "a4d3cf8e2c07...",
    "device_owner": "corp_macbook_7"
  }
}`}</code></pre>
					</div>
				</div>
			</div>
			<div class="flex justify-between items-center px-1">
				<span class="text-dim text-xs select-none">Simulated browser-edge Manifest V3 intercept. Running locally.</span>
				<span class="text-dim text-xs">Fail-Closed Mode: On</span>
			</div>
		</div>

		<!-- Section: Browser-edge Sanitation -->
		<div class="pt-4 mb-16">
			<h2 class="text-dim border-l-2 border-accent pl-4 mb-6">Browser-edge sanitation (ChatGPT & Claude.ai)</h2>
			<p class="text-dim text-sm leading-relaxed mb-4">
				Truss extends local governance past the CLI surface by hooking <code>window.fetch()</code> directly inside web clients. Unmanaged employees can write code and prompt frontier models freely while our lightweight background proxy protects your sensitive IP.
			</p>
			<ul class="list-disc pl-5 text-dim text-sm space-y-2 mb-6">
				<li><strong>Zero optimistic leaks:</strong> Intercepts raw prompts before the UI can render or transmit.</li>
				<li><strong>Fail-closed architecture:</strong> If the local daemon or enterprise proxy is unreachable, outbound prompt transmissions are blocked instantly.</li>
				<li><strong>Local YAML rule sets:</strong> Configure allows, blocks, and redactions within simple, version-controlled YAML files.</li>
			</ul>
		</div>

		<!-- Section: Process-level Wrap -->
		<div class="pt-4 mb-16">
			<h2 class="text-dim border-l-2 border-accent pl-4 mb-6">Process-level wrap (Developer CLI)</h2>
			<p class="text-dim text-sm leading-relaxed mb-4">
				You don't need to rebuild your agents or modify their codebase. Truss wraps existing tools (like <code>gemini-cli</code>, in-house python pipelines, Cursor, or SDK-based agents) by pointing their client base-URLs at a local uvicorn proxy on your machine.
			</p>
			<pre class="bg-surface border border-border-dim rounded p-4 overflow-x-auto text-sm leading-relaxed"><code># Install (bootstraps a private venv + ledger under ~/.truss/)
curl -sSL https://trusslabs.org/install.sh | bash

# Wrap gemini-cli (works the same for `claude` — sets ANTHROPIC_BASE_URL)
truss proxy exec -- gemini-cli

# Inside the wrapped CLI, ask something that contains a patient address:
#   → Patient lives at 1234 Main St. Summarize their case.
# Truss intercepts before the model sees it. Receipt:
ls ~/.truss/ledger/receipts/$(date -u +%F)/

# An auditor can verify every receipt in the ledger:
truss receipt verify ~/.truss/ledger/receipts</code></pre>

			<p class="text-dim text-sm leading-relaxed pt-4">
				Provider-agnostic by design — Gemini and Claude both wired today; OpenAI is the same reverse-proxy shape. Truss holds no upstream model credentials. The wrapped CLI's own API key (or OAuth token) flows through the inbound request and truss forwards it.
			</p>
		</div>

		<!-- Section: Confidential Enclave Deployment -->
		<div class="pt-4 mb-16">
			<h2 class="text-dim border-l-2 border-accent pl-4 mb-6">Confidential enclave deployment</h2>
			<p class="text-dim text-sm leading-relaxed mb-4">
				For zero-trust enterprise security, the Truss proxy container is designed to compile directly into a bootable Enclave Image File (EIF). Running inside AWS Nitro Enclaves or GCP Confidential Space, the CPU encrypts memory at the hardware layer, shielding prompts in-flight even from root cloud administrators.
			</p>
			<pre class="bg-surface border border-border-dim rounded p-4 overflow-x-auto text-sm leading-relaxed"><code># Compile the audit proxy to an AWS Nitro EIF
nitro-cli build-enclave --docker-uri truss-audit-proxy:latest --output-file truss-proxy.eif

# The physical CPU validates the image hash (PCR0)
# Enclave pulls policy decryption keys from KMS only on successful hardware attestation</code></pre>
			<p class="text-dim text-sm leading-relaxed pt-4">
				By handling data scrubbing and immutable auditing inside an isolated, hardware-verified runtime, the underlying model is reduced to a stateless utility. You can hot-swap APIs or model providers in minutes without rewriting your security boundary.
			</p>
		</div>

		<!-- Section: Offline Trace Analysis -->
		<div class="pt-4 mb-16">
			<h2 class="text-dim border-l-2 border-accent pl-4 mb-6">Offline trace analysis</h2>
			<p class="text-dim text-sm leading-relaxed mb-4">
				Rather than locking you into a monolithic security suite, Truss handles post-incident analysis by treating security as a chain of small, composable command-line tools. Following the classic Unix philosophy of doing one thing well, each utility reads standard input, applies a single transform, and outputs structured JSON streams for the next command:
			</p>
			<ul class="list-disc pl-5 text-dim text-sm space-y-2 mb-6">
				<li><code>truss trace translate</code> reads flat, raw agent logs (e.g., standard JSONL hooks) and parses them into a structured execution tree.</li>
				<li><code>truss trace analyze</code> takes that tree and flags behavioral anomalies, such as tight model-retry loops or circular-reasoning stalls.</li>
				<li><code>truss trap</code> scans the output stream in real-time and executes immediate countermeasures (like halting a runaway loop or raising a SIEM alert).</li>
			</ul>
			<p class="text-dim text-sm leading-relaxed mb-4">
				By piping these utilities together using standard shell operators, you can construct highly flexible, auditable guardrail pipelines with zero runtime dependencies:
			</p>
			<pre class="bg-surface border border-border-dim rounded p-4 overflow-x-auto text-xs leading-relaxed"><code>cat hooks.jsonl | truss trace translate | truss trace analyze --json --flag FLAG_CIRCULAR_REASONING | truss trap run</code></pre>
			<p class="text-dim text-sm leading-relaxed pt-4">
				Source: <a href="https://github.com/trusslabs-org/truss-labs">github.com/trusslabs-org/truss-labs</a>. Interactive sandbox: <a href="/sandbox">trusslabs.org/sandbox</a>.
			</p>
		</div>

		<div class="pt-4">
			<p class="text-dim text-sm leading-relaxed">
				Status: pre-product as a SKU. First validated discovery call: 2026.05.07. Live demo up. Building toward a paid pilot. I'm writing about the work as it ships rather than waiting for a launch.
			</p>
		</div>

		<!-- Interactive Browser Simulator Script (Non-Reflowing Unified Loop) -->
		<script>
			const promptText = "Patient lives at 1234 Main St. Summarize this note.";
			
			// DOM Cache
			const promptInput = document.getElementById('prompt-input');
			const promptInputContainer = document.getElementById('prompt-input-container');
			const btnSend = document.getElementById('btn-send');
			const extIndicator = document.getElementById('extension-indicator');
			const extText = document.getElementById('extension-text');
			const msgUser = document.getElementById('msg-user');
			const msgUserText = document.getElementById('msg-user-text');
			const msgAlert = document.getElementById('msg-alert');
			const logEvent = document.getElementById('log-event');
			const logReceipt = document.getElementById('log-receipt');

			function runSimulation() {
				// 1. Reset all elements to baseline
				promptInput.textContent = "";
				promptInputContainer.style.opacity = "1";
				btnSend.classList.remove('bg-accent/10', 'border-accent/30', 'text-accent');
				
				extIndicator.classList.remove('bg-red-500', 'bg-yellow-500');
				extIndicator.classList.add('bg-accent');
				extText.textContent = "truss active";
				extText.classList.remove('text-red-400');
				extText.classList.add('text-accent');

				msgUser.classList.add('opacity-0');
				msgUserText.textContent = "";
				msgAlert.classList.add('opacity-0', 'translate-y-2');
				logEvent.classList.add('opacity-0');
				logReceipt.classList.add('opacity-0', 'translate-y-1');

				let charIndex = 0;

				// 2. Typing Phase
				function typeCharacter() {
					if (charIndex < promptText.length) {
						promptInput.textContent += promptText[charIndex];
						charIndex++;
						setTimeout(typeCharacter, 55);
					} else {
						// Typing complete, trigger send button click
						setTimeout(triggerSendClick, 500);
					}
				}

				// 3. Send Click & Pulsing Intercept
				function triggerSendClick() {
					btnSend.classList.add('bg-accent/10', 'border-accent/30', 'text-accent');
					
					setTimeout(() => {
						promptInputContainer.style.opacity = "0.3";
						extIndicator.classList.remove('bg-accent');
						extIndicator.classList.add('bg-yellow-500');
						extText.textContent = "intercepting";
						extText.classList.remove('text-accent');
						extText.classList.add('text-yellow-400');

						setTimeout(triggerBlockPhase, 900);
					}, 300);
				}

				// 4. Local Blocking & Warning Card animation
				function triggerBlockPhase() {
					extIndicator.classList.remove('bg-yellow-500');
					extIndicator.classList.add('bg-red-500');
					extText.textContent = "blocked";
					extText.classList.remove('text-yellow-400');
					extText.classList.add('text-red-400');

					msgUserText.textContent = promptText;
					msgUser.classList.remove('opacity-0');

					setTimeout(() => {
						msgAlert.classList.remove('opacity-0', 'translate-y-2');
						triggerLogPhase();
					}, 500);
				}

				// 5. Local Ledger compliance write
				function triggerLogPhase() {
					setTimeout(() => {
						logEvent.classList.remove('opacity-0');
						setTimeout(() => {
							logReceipt.classList.remove('opacity-0', 'translate-y-1');
						}, 400);
					}, 800);
				}

				// Initiate Typing Start
				setTimeout(typeCharacter, 400);
			}

			// Run immediately and schedule the 15-second loop
			runSimulation();
			setInterval(runSimulation, 15000);
		</script>
	</main>
</Layout>