---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
	<article class="pb-6">
		<header class="mb-12 border-b border-border-dim pb-6">
			<time class="text-xs text-dim uppercase tracking-widest">{post.data.date}</time>
			<h1 class="text-3xl text-text mt-2 font-bold tracking-tight">{post.data.title}</h1>
		</header>
		<div class="blog-content">
			<Content />
		</div>
	</article>
</Layout>

<style is:global>
	.blog-content p {
		color: var(--sys-color-text-dim);
		font-size: 0.875rem;
		line-height: 1.625;
		margin-bottom: 1.5rem;
	}
	.blog-content h2 {
		color: var(--sys-color-accent);
		font-size: 1.25rem;
		border-bottom: 1px solid var(--sys-color-border);
		padding-bottom: 0.5rem;
		margin-top: 3rem;
		margin-bottom: 1.5rem;
		font-weight: 700;
		letter-spacing: -0.025em;
	}
	.blog-content ul {
		list-style-type: disc;
		padding-left: 1.25rem;
		color: var(--sys-color-text-dim);
		font-size: 0.875rem;
		line-height: 1.625;
		margin-bottom: 1.5rem;
	}
	.blog-content ol {
		list-style-type: decimal;
		padding-left: 1.25rem;
		color: var(--sys-color-text-dim);
		font-size: 0.875rem;
		line-height: 1.625;
		margin-bottom: 1.5rem;
	}
	.blog-content li {
		padding-left: 0.25rem;
		margin-bottom: 0.5rem;
	}
	.blog-content strong {
		color: var(--sys-color-text);
		font-weight: 700;
	}
	.blog-content pre {
		background-color: #141414 !important;
		border: 1px solid var(--sys-color-border);
		border-radius: 0.25rem;
		padding: 1rem;
		overflow-x: auto;
		font-size: 0.75rem;
		margin-bottom: 1.5rem;
	}
	.blog-content code {
		color: var(--sys-color-accent);
		font-family: var(--sys-font-mono);
		background-color: var(--sys-color-surface);
		padding: 0.125rem 0.375rem;
		border-radius: 0.125rem;
		font-size: 11px;
		border: 1px solid var(--sys-color-border);
	}
	.blog-content pre code {
		padding: 0;
		background-color: transparent;
		border: none;
		font-size: 0.75rem;
	}
	.blog-content a {
		color: var(--sys-color-accent);
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-underline-offset: 4px;
	}
	.blog-content a:hover {
		text-decoration: none;
	}
	.blog-content blockquote {
		border-left: 2px solid var(--sys-color-accent);
		padding-left: 1rem;
		font-style: italic;
		margin-top: 1.5rem;
		margin-bottom: 1.5rem;
		color: var(--sys-color-text-dim);
	}
</style>
