---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Deck" description="AI activity visibility on infrastructure you control">
	<section class="space-y-6">
		<h2 class="text-dim border-l-2 border-accent pl-4">Deck</h2>
		<p class="text-xl leading-relaxed">
			The deck is no longer published at this URL.
		</p>
		<p class="text-dim leading-relaxed">
			For the current public work, use the live demo or source repository.
		</p>
		<div class="flex flex-col sm:flex-row gap-4 text-sm">
			<a href="https://demo.trusslabs.org">Live demo</a>
			<a href="https://github.com/trusslabs-org/truss-labs">Source</a>
			<a href="/">Home</a>
		</div>
	</section>
</Layout>
