---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "AI activity visibility on infrastructure you control" } = Astro.props;
const usePaperTheme = Astro.url.pathname.startsWith('/docs') || Astro.url.pathname.startsWith('/blog');
---

<!doctype html>
<html lang="en" data-theme={usePaperTheme ? 'paper' : 'dark'}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Truss Labs</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
		<style is:global>
			@import "tailwindcss";
			@import "../styles/tokens.css";
			:root {
				background-color: var(--color-bg);
				color: var(--color-text);
				font-family: var(--font-mono);
			}
			body {
				@apply p-6 md:p-12 max-w-3xl mx-auto;
			}
			h1, h2, h3 {
				@apply font-bold tracking-tight;
			}
			a {
				@apply text-accent hover:underline decoration-1 underline-offset-4;
			}
		</style>
	</head>
	<body class="bg-bg text-text selection:bg-accent selection:text-bg">
		<header class="mb-16 border-b border-border-dim pb-8 flex flex-row justify-between items-baseline gap-4 flex-wrap">
			<div class="flex flex-row items-baseline gap-4 shrink min-w-0">
				<h1 class="text-2xl text-accent font-bold tracking-tight whitespace-nowrap shrink-0">
					<a href="/" class="hover:no-underline text-accent">Truss Labs Inc.</a>
				</h1>
				<span class="text-dim text-sm truncate">AI activity visibility on infrastructure you control</span>
			</div>
			<nav class="flex gap-6 text-sm shrink-0">
				<a href="/blog">Blog</a>
				<a href="/governance">Governance</a>
				<a href="https://github.com/trusslabs-org/truss-labs">Source</a>
				<a href="mailto:contact@trusslabs.org">Contact</a>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="mt-24 pt-8 border-t border-border-dim text-dim text-xs flex flex-col md:flex-row justify-between gap-4">
			<div>&copy; {new Date().getFullYear()} Truss Labs Inc.</div>
		</footer>
	</body>
</html>
